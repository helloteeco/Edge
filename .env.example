# Edge by Teeco - Environment Variables
# Copy this file to .env.local and fill in your values

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: API Keys for future features
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx
# AIRDNA_API_KEY=your_airdna_key
# ZILLOW_API_KEY=your_zillow_key

# Airbtics API (primary STR data source - more accurate than Mashvisor)
# Get your key at https://app.airbtics.com/api-dashboard
AIRBTICS_API_KEY=your_airbtics_key

# PriceLabs API (PRIMARY revenue/ADR/occupancy source for calculator analyses)
# Required for accurate licensed STR market data — without this key the calculator
# falls back to Airbnb-only derived metrics, which is less accurate.
# Get your key at https://hello.pricelabs.co/data/
PRICELABS_API_KEY=your_pricelabs_key

# Optional: Email service for mentorship leads
# SENDGRID_API_KEY=SG.xxxxx
# CONTACT_EMAIL=hello@teeco.co
